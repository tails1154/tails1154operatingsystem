#!/usr/bin/env bash
set -euo pipefail

MARKER="$HOME/.config/tails1154-firstboot-done"
[[ -f "$MARKER" ]] && exit 0

# Wait for NetworkManager
for i in $(seq 30); do
    nmcli -t -f STATE g 2>/dev/null | grep -q connected && break
    sleep 2
done

# Start ollama if not running
ollama serve &>/dev/null &
sleep 3

# Pull models with progress
for model in llama3.2:3b qwen2.5:1.5b; do
    dbus-launch kdialog --progressbar "Downloading $model..." 0 | \
        while read -r dbus_ref; do
            ollama pull "$model" 2>&1 | while IFS= read -r line; do
                if [[ "$line" =~ ([0-9]+)% ]]; then
                    qdbus "$dbus_ref" Set "" value "${BASH_REMATCH[1]}"
                fi
            done
            qdbus "$dbus_ref" close
        done
done

touch "$MARKER"
kdialog --msgbox "AI models downloaded! You can now use Ollama."
