#!/usr/bin/env bash
set -uo pipefail

MARKER="$HOME/.config/tails1154-firstboot-done"
[[ -f "$MARKER" ]] && exit 0

# Wait for network
for i in $(seq 30); do
    nmcli -t -f STATE g 2>/dev/null | grep -q connected && break
    sleep 2
done

# Kill everything so they can't escape
killall plasmashell krunner kwin_x11 kwin_wayland 2>/dev/null || true
sleep 1

# Fullscreen takeover
dbus_ref=$(kdialog --geometry 1280x720+0+0 --title "tails1154OS First Boot" --progressbar "Preparing your system..." 0) || exit 0

update() { qdbus "$dbus_ref" setLabelText "$1" 2>/dev/null || true; }
close()  { qdbus "$dbus_ref" close 2>/dev/null || true; }

update "Starting Ollama..."
ollama serve &>/dev/null &
sleep 3

for model in llama3.2:3b qwen2.5:1.5b; do
    update "Downloading AI model: $model (this may take a while)"
    ollama pull "$model" 2>/dev/null || true
done

update "Setting up Flathub..."
flatpak remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo 2>/dev/null || true

update "Installing Sober (Roblox) + Vesktop (Discord)..."
flatpak install -y flathub org.vinegarhq.Sober dev.vencord.Vesktop 2>/dev/null || true

close

# Restart Plasma
nohup plasmashell &>/dev/null &
disown

touch "$MARKER"
kdialog --title "tails1154OS" --msgbox "All done!\n\nAI models: llama3.2 + qwen2.5 ready to use\nSober (Roblox) installed\nVesktop (Discord) installed\n\nEnjoy your bloat." 2>/dev/null || true
